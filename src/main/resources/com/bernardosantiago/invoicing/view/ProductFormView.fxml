<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bernardosantiago.invoicing.controller.ProductFormController"
            styleClass="app-shell">

  <top>
    <HBox alignment="CENTER_LEFT" spacing="16" styleClass="top-bar">
      <VBox spacing="4" HBox.hgrow="ALWAYS">
        <Label text="Register Product" styleClass="screen-title"/>
        <Label text="Add a catalog item that can be used in future invoices." styleClass="screen-subtitle"/>
      </VBox>

      <VBox alignment="CENTER_RIGHT" spacing="4" styleClass="invoice-number-box">
        <Label text="Catalog" styleClass="eyebrow-label"/>
        <Label text="New Product" styleClass="invoice-number"/>
      </VBox>
    </HBox>
  </top>

  <center>
    <StackPane styleClass="content-area">
      <VBox spacing="18" maxWidth="760" styleClass="invoice-panel product-form-panel">
        <GridPane hgap="14" vgap="12" styleClass="form-grid">
          <columnConstraints>
            <ColumnConstraints percentWidth="60"/>
            <ColumnConstraints percentWidth="40"/>
          </columnConstraints>

          <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <Label text="Product Name" styleClass="field-label"/>
            <TextField fx:id="productNameField" promptText="Product name"/>
          </VBox>

          <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <Label text="SKU" styleClass="field-label"/>
            <TextField fx:id="skuField" promptText="SKU"/>
          </VBox>

          <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
            <Label text="Unit Price" styleClass="field-label"/>
            <TextField fx:id="unitPriceField" promptText="\$0.00"/>
          </VBox>
        </GridPane>

        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="form-action-row">
          <Region HBox.hgrow="ALWAYS"/>
          <Button fx:id="cancelProductButton" text="Cancel" onAction="#handleCancel" styleClass="secondary-button"/>
          <Button fx:id="saveProductButton" text="Save Product" onAction="#handleSaveProduct" styleClass="primary-button"/>
        </HBox>
      </VBox>
    </StackPane>
  </center>

  <padding>
    <Insets top="0" right="0" bottom="0" left="0"/>
  </padding>
</BorderPane>
